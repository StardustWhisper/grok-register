# --- 运行配置 ---
RUN_COUNT=10
# DuckMail/API 请求代理（可选）
PROXY=""
# 浏览器代理，无头服务器需翻墙时填写（可选）
BROWSER_PROXY=""

# --- Grok2API 配置 ---
# grok2api 管理接口地址，留空跳过推送
GROK2API_ENDPOINT="https://your-grok2api-domain.com"
# grok2api 的 app_key
GROK2API_TOKEN="your_app_key_here"

# --- 临时邮箱配置 (cloudflare_temp_email) ---
TEMP_MAIL_BASE="https://your-temp-mail-api.com"
TEMP_MAIL_ADMIN_PASSWORD="your_admin_password_here"
# 邮箱域名列表，英文逗号分隔
TEMP_MAIL_DOMAINS="example.com,test.com"
# 跳过网络连通性检查 (1: 是, 0: 否)
SKIP_NET_CHECK="1"
